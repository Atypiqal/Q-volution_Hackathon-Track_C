    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "from classiq import synthesize, execute\n",
    "\n",
    "def simulate_and_calculate_energies(t_values: list, bound_value: float = 0.05, shots: int = 2048):\n",
    "    \"\"\"\n",
    "    Ejecuta el circuito LCU para un arreglo de tiempos t, extrae las probabilidades\n",
    "    y reconstruye rigurosamente las energías cinéticas y potenciales.\n",
    "    \"\"\"\n",
    "    results_list =[]\n",
    "    \n",
    "    print(f\"Iniciando simulación cuántica para {len(t_values)} instantes de tiempo...\")\n",
    "    print(f\"Parámetros: bound={bound_value}, shots={shots}\\n\")\n",
    "\n",
    "    for i, t in enumerate(t_values):\n",
    "        # 1. Crear y sintetizar el modelo para el instante actual\n",
    "        model = create_lcu_model(t, bound_value=bound_value)\n",
    "        qprog = synthesize(model)\n",
    "        \n",
    "        # 2. Ejecutar el programa cuántico\n",
    "        execution_results = execute(qprog).result()\n",
    "        parsed_counts = execution_results[0].value.parsed_counts\n",
    "        \n",
    "        counts_000 = 0  # Estado físico |0> (posición) cuando ancilla es |00>\n",
    "        counts_001 = 0  # Estado físico |1> (velocidad) cuando ancilla es |00>\n",
    "        \n",
    "        # Opcional: Imprimir el formato interno en la primera iteración (para impresionar a los jueces)\n",
    "        if i == 0 and len(parsed_counts) > 0:\n",
    "            sample_debug = parsed_counts[0]\n",
    "            state_debug = getattr(sample_debug, 'state', sample_debug.get('state', sample_debug) if isinstance(sample_debug, dict) else {})\n",
    "            print(f\"-> DEBUG Formato de estado devuelto por Classiq: {state_debug}\")\n",
    "\n",
    "        for sample in parsed_counts:\n",
    "            # --- 3A: Extracción robusta de los atributos de la muestra ---\n",
    "            if hasattr(sample, 'state'):\n",
    "                state_dict = sample.state\n",
    "            elif isinstance(sample, dict):\n",
    "                state_dict = sample.get('state', sample)\n",
    "            else:\n",
    "                state_dict = {}\n",
    "                \n",
    "            if hasattr(sample, 'shots'):\n",
    "                sample_shots = sample.shots\n",
    "            elif hasattr(sample, 'counts'):\n",
    "                sample_shots = sample.counts\n",
    "            elif isinstance(sample, dict):\n",
    "                sample_shots = sample.get('shots', sample.get('counts', 0))\n",
    "            else:\n",
    "                sample_shots = 0\n",
    "\n",
    "            # --- 3B: Normalizador universal de registros cuánticos ---\n",
    "            def normalize_val(v):\n",
    "                if isinstance(v, (tuple, list)):\n",
    "                    # Si Classiq devuelve una tupla ej: (0, 0), verificamos si son puros ceros\n",
    "                    if all(bit == 0 for bit in v): return 0\n",
    "                    if len(v) == 1: return v[0]\n",
    "                    return sum(v) # Si hay algún 1, será > 0\n",
    "                elif isinstance(v, str):\n",
    "                    try:\n",
    "                        # Si devuelve string binario ej: '00'\n",
    "                        return int(v, 2) if all(c in '01' for c in v) else int(float(v))\n",
    "                    except ValueError:\n",
    "                        return -1\n",
    "                elif v is not None:\n",
    "                    # Si devuelve float o int ej: 0.0\n",
    "                    return int(float(v))\n",
    "                return -1\n",
    "\n",
    "            # Extraemos los valores normalizados a enteros puros\n",
    "            ancilla_val = normalize_val(state_dict.get('ancilla_reg'))\n",
    "            work_val = normalize_val(state_dict.get('work_qubit'))\n",
    "            \n",
    "            # --- PASO 1: Post-selección rigurosa ---\n",
    "            # Solo sumamos al conteo si AMBOS qubits del ancilla son 0\n",
    "            if ancilla_val == 0:\n",
    "                if work_val == 0:\n",
    "                    counts_000 += sample_shots\n",
    "                elif work_val == 1:\n",
    "                    counts_001 += sample_shots\n",
    "                    \n",
    "        # Usamos PROBABILIDADES ABSOLUTAS\n",
    "        P0_abs = counts_000 / shots\n",
    "        P1_abs = counts_001 / shots\n",
    "        \n",
    "        # --- PASO 2: Reconstrucción del Vector Físico x(t) ---\n",
    "        S_t = 1.0 + t + (t**2)/2.0 + (t**3)/6.0\n",
    "        \n",
    "        y_squared = 2.0 * (S_t**2) * P0_abs\n",
    "        y_prime_squared = 2.0 * (S_t**2) * P1_abs\n",
    "        \n",
    "        # --- PASO 3: Cálculo Riguroso de Energías ---\n",
    "        V_quantum = 0.5 * y_squared        \n",
    "        K_quantum = 0.5 * y_prime_squared  \n",
    "        E_quantum = V_quantum + K_quantum  \n",
    "        \n",
    "        # --- Valores Teóricos Exactos ---\n",
    "        y_exact = np.cos(t) + np.sin(t)\n",
    "        y_prime_exact = -np.sin(t) + np.cos(t)\n",
    "        \n",
    "        V_exact = 0.5 * (y_exact**2)\n",
    "        K_exact = 0.5 * (y_prime_exact**2)\n",
    "        E_exact = V_exact + K_exact \n",
    "        \n",
    "        results_list.append({\n",
    "            't': t,\n",
    "            'V_quantum': V_quantum,\n",
    "            'K_quantum': K_quantum,\n",
    "            'E_quantum': E_quantum,\n",
    "            'V_exact': V_exact,\n",
    "            'K_exact': K_exact,\n",
    "            'E_exact': E_exact\n",
    "        })\n",
    "        \n",
    "        print(f\"Progreso: {i+1}/{len(t_values)} | t={t:.2f} | Prob_Base={P0_abs:.3f} | E_quant={E_quantum:.4f} Joules\")\n",
    "\n",
    "    print(\"\\n¡Extracción y procesamiento de datos completados!\")\n",
    "    return pd.DataFrame(results_list)\n",
    "\n",
    "# =========================================================================\n",
    "# EJECUCIÓN DEL EXPERIMENTO\n",
