    "import numpy as np\n",
    "from classiq import *\n",
    "\n",
    "def create_lcu_model(t: float, bound_value: float):\n",
    "    \"\"\"\n",
    "    Genera el modelo cuántico LCU para resolver el oscilador armónico en un instante t.\n",
    "    \"\"\"\n",
    "    \n",
    "    # 1. Calculamos los pesos de la serie de Taylor teóricos\n",
    "    w0 = 1.0\n",
    "    w1 = t\n",
    "    w2 = (t**2) / 2.0\n",
    "    w3 = (t**3) / 6.0\n",
    "    \n",
    "    # 2. Probabilidades proporcionales a w_m\n",
    "    total_w = w0 + w1 + w2 + w3\n",
    "    P =[\n",
    "        float(w0 / total_w), \n",
    "        float(w1 / total_w), \n",
    "        float(w2 / total_w), \n",
    "        float(w3 / total_w)\n",
    "    ]\n",
    "\n",
    "    @qfunc\n",
    "    def prepare_ancillas(ancilla_reg: QArray[QBit]):\n",
    "        inplace_prepare_state(probabilities=P, bound=bound_value, target=ancilla_reg)\n",
    "\n",
    "    @qfunc\n",
    "    def lcu_algorithm(work_qubit: QArray[QBit], ancilla_reg: QArray[QBit]):\n",
    "        H(work_qubit[0])\n",
    "        \n",
    "        prepare_ancillas(ancilla_reg)\n",
    "        \n",
    "        # =========================================================================\n",
    "        # SOLUCIÓN DEL ERROR: Argumentos posicionales para evitar el NameError\n",
    "        # =========================================================================\n",
    "        control(ancilla_reg[0], lambda: RY(-np.pi, work_qubit[0]))\n",
    "        \n",
    "        Z(ancilla_reg[1])\n",
    "        \n",
    "        invert(lambda: prepare_ancillas(ancilla_reg))\n",
    "\n",
    "    @qfunc\n",
    "    def main(work_qubit: Output[QArray[QBit]], ancilla_reg: Output[QArray[QBit]]):\n",
    "        allocate(1, work_qubit)\n",
    "        allocate(2, ancilla_reg)\n",
    "        lcu_algorithm(work_qubit, ancilla_reg)\n",
    "\n",
    "    return create_model(main)"
   ]
  },
