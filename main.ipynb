    "import numpy as np\n",
    "import pandas as pd\n",
    "import matplotlib.pyplot as plt\n",
    "import seaborn as sns\n",
    "import json\n",
    "from classiq import synthesize, set_preferences, Preferences\n",
    "from classiq.execution import ExecutionPreferences\n",
    "\n",
    "# Configuramos el estilo de las gráficas\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "plt.rcParams.update({'font.size': 12})\n",
    "\n",
    "# =========================================================================\n",
    "# ANÁLISIS PARAMÉTRICO: El impacto del 'bound'\n",
    "# =========================================================================\n",
    "print(\"Iniciando Análisis de Precisión (Bounds)...\")\n",
    "test_bounds =[0.001, 0.01, 0.05, 0.1, 0.2, 0.5] \n",
    "t_test = 1.0 # Usamos t=1.0 porque es donde la serie de Taylor tiene mayor peso\n",
    "\n",
    "bound_results =[]\n",
    "\n",
    "for b in test_bounds:\n",
    "    # 1. Ejecutar modelo\n",
    "    model_b = create_lcu_model(t=t_test, bound_value=b)\n",
    "    qprog_b = synthesize(model_b)\n",
    "    res_b = execute(qprog_b).result()\n",
    "    parsed_b = res_b[0].value.parsed_counts\n",
    "    \n",
    "    # 2. Extracción (usando nuestra lógica robusta)\n",
    "    counts_000, counts_001 = 0, 0\n",
    "    total_shots_reales = 0  # <--- CORRECCIÓN 1: Contaremos los shots reales\n",
    "    \n",
    "    for sample in parsed_b:\n",
    "        st = sample.state if hasattr(sample, 'state') else sample.get('state', sample)\n",
    "        sh = sample.shots if hasattr(sample, 'shots') else sample.get('shots', sample.get('counts', 0))\n",
    "        \n",
    "        total_shots_reales += sh # Sumamos los shots que Classiq realmente ejecutó\n",
    "        \n",
    "        def norm(v):\n",
    "            if isinstance(v, (tuple, list)): return 0 if all(bit==0 for bit in v) else sum(v)\n",
    "            if isinstance(v, str): return int(v, 2) if all(c in '01' for c in v) else -1\n",
    "            return int(float(v)) if v is not None else -1\n",
    "            \n",
    "        a_val, w_val = norm(st.get('ancilla_reg')), norm(st.get('work_qubit'))\n",
    "        \n",
    "        if a_val == 0:\n",
    "            if w_val == 0: counts_000 += sh\n",
    "            elif w_val == 1: counts_001 += sh\n",
    "\n",
    "    # Calculamos con el total absoluto real\n",
    "    P0 = counts_000 / total_shots_reales\n",
    "    P1 = counts_001 / total_shots_reales\n",
    "    \n",
    "    # 3. Física\n",
    "    S_t = 1.0 + t_test + (t_test**2)/2.0 + (t_test**3)/6.0\n",
    "    E_quant = 0.5 * (2 * (S_t**2) * P0) + 0.5 * (2 * (S_t**2) * P1)\n",
    "    \n",
    "    # Error Absoluto respecto a la energía teórica (1.0)\n",
    "    error = abs(E_quant - 1.0)\n",
    "    bound_results.append({'bound': b, 'error': error})\n",
    "    print(f\"Bound: {b} -> Error de Energía: {error:.4f} Joules\")\n",
    "\n",
    "df_bounds = pd.DataFrame(bound_results)\n",
    "\n",
    "# =========================================================================\n",
    "# ANÁLISIS DE EFICIENCIA: Profundidad vs Anchura\n",
    "# =========================================================================\n",
    "print(\"\\nIniciando Análisis de Recursos de Hardware...\")\n",
    "\n",
    "def get_metrics(qprog_obj):\n",
    "    \"\"\"Extrae profundidad y anchura de forma programática y sin Warnings de Pydantic\"\"\"\n",
    "    try:\n",
    "        # Solución al Warning de Pydantic V2\n",
    "        if isinstance(qprog_obj, str):\n",
    "            data = json.loads(qprog_obj)\n",
    "        elif hasattr(qprog_obj, 'model_dump_json'):\n",
    "            data = json.loads(qprog_obj.model_dump_json())\n",
    "        else:\n",
    "            data = json.loads(qprog_obj.json())\n",
    "            \n",
    "        def find_k(obj, key):\n",
    "            if isinstance(obj, dict):\n",
    "                if key in obj: return obj[key]\n",
    "                for k, v in obj.items():\n",
    "                    res = find_k(v, key)\n",
    "                    if res is not None: return res\n",
    "            elif isinstance(obj, list):\n",
    "                for item in obj:\n",
    "                    res = find_k(item, key)\n",
    "                    if res is not None: return res\n",
    "            return None\n",
    "            \n",
    "        return find_k(data, 'depth'), find_k(data, 'width') or find_k(data, 'num_qubits')\n",
    "    except Exception as e:\n",
    "        print(f\"Error extrayendo métricas: {e}\")\n",
    "        return 0, 0\n",
    "\n",
    "# Manejo seguro de Preferencias según versión de Classiq\n",
    "try:\n",
    "    from classiq import OptimizationParameter\n",
    "    pref_d = Preferences(optimization_parameter=OptimizationParameter.DEPTH)\n",
    "    pref_w = Preferences(optimization_parameter=OptimizationParameter.WIDTH)\n",
    "except Exception:\n",
    "    pref_d = Preferences()\n",
    "    pref_w = Preferences()\n",
    "\n",
    "# 1. Optimización por Profundidad\n",
    "model_d = create_lcu_model(t=1.0, bound_value=0.01)\n",
    "# <--- CORRECCIÓN 2: Argumentos en orden correcto (modelo, preferencias)\n",
    "model_d = set_preferences(model_d, pref_d) \n",
    "qprog_d = synthesize(model_d)\n",
    "depth_d, width_d = get_metrics(qprog_d)\n",
    "\n",
    "# 2. Optimización por Anchura\n",
    "model_w = create_lcu_model(t=1.0, bound_value=0.01)\n",
    "# <--- CORRECCIÓN 2: Argumentos en orden correcto\n",
    "model_w = set_preferences(model_w, pref_w) \n",
    "qprog_w = synthesize(model_w)\n",
    "depth_w, width_w = get_metrics(qprog_w)\n",
    "\n",
    "df_resources = pd.DataFrame({\n",
    "    'Estrategia':['Optimizado para Profundidad', 'Optimizado para Anchura'],\n",
    "    'Profundidad (Depth)': [depth_d, depth_w],\n",
    "    'Cúbits (Width)':[width_d, width_w]\n",
    "})\n",
    "\n",
    "display(df_resources)\n",
    "\n",
    "# =========================================================================\n",
    "# GRÁFICA 2 y 3: Entregables Analíticos Finales\n",
    "# =========================================================================\n",
    "fig, ax = plt.subplots(1, 2, figsize=(15, 5))\n",
    "\n",
    "# Gráfica de Bounds\n",
    "ax[0].plot(df_bounds['bound'], df_bounds['error'], marker='s', color='purple', linewidth=2)\n",
    "ax[0].set_xscale('log')\n",
    "ax[0].set_title(\"Trade-off: Tolerancia vs Error Físico\")\n",
    "ax[0].set_xlabel(\"Límite de Tolerancia (Bound) [Escala Log]\")\n",
    "ax[0].set_ylabel(\"Error Absoluto de Energía (Joules)\")\n",
    "ax[0].invert_xaxis() # Invertimos para que la mayor precisión esté a la derecha\n",
    "\n",
    "# Gráfica de Recursos\n",
    "df_resources.set_index('Estrategia').plot(kind='bar', ax=ax[1], colormap='viridis')\n",
    "ax[1].set_title(\"Uso de Recursos según Preferencia de Síntesis\")\n",
    "ax[1].set_ylabel(\"Cantidad\")\n",
    "ax[1].tick_params(axis='x', rotation=0)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
